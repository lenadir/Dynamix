@page "/admin"
@attribute [Authorize]

<h2 style="margin-bottom:.25rem;">Administration</h2>
<p style="color:var(--text-light); font-size:.9rem; margin-bottom:1.5rem;">Tenant configuration and system settings.</p>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
    <div class="data-table-wrap" style="padding:1.5rem;">
        <h3 style="font-size:1rem; margin-bottom:1rem;">Current Tenant</h3>
        <div class="form-group">
            <label>Tenant ID</label>
            <input readonly value="11111111-1111-1111-1111-111111111111" style="background:#F3F2F1;" />
        </div>
        <div class="form-group">
            <label>Company Name</label>
            <input readonly value="Demo Corporation Ltd." style="background:#F3F2F1;" />
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Currency</label>
                <input readonly value="USD" style="background:#F3F2F1;" />
            </div>
            <div class="form-group">
                <label>Status</label>
                <input readonly value="Active" style="background:#F3F2F1;" />
            </div>
        </div>
    </div>

    <div class="data-table-wrap" style="padding:1.5rem;">
        <h3 style="font-size:1rem; margin-bottom:1rem;">System Info</h3>
        <table class="data-table" style="font-size:.875rem;">
            <tbody>
                <tr><td style="font-weight:600;">Runtime</td><td>.NET 8</td></tr>
                <tr><td style="font-weight:600;">Architecture</td><td>Modular Monolith</td></tr>
                <tr><td style="font-weight:600;">Database</td><td>SQL Server (shared schema)</td></tr>
                <tr><td style="font-weight:600;">Messaging</td><td>MassTransit + RabbitMQ</td></tr>
                <tr><td style="font-weight:600;">CQRS</td><td>MediatR</td></tr>
                <tr><td style="font-weight:600;">Validation</td><td>FluentValidation</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="data-table-wrap" style="padding:1.5rem; margin-top:1.25rem;">
    <h3 style="font-size:1rem; margin-bottom:1rem;">Active Modules</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:1rem;">
        <div style="background:#E3F2FD; border-radius:8px; padding:1rem;">
            <strong>💼 Dynamix Sales</strong>
            <p style="font-size:.8rem; color:var(--text-light); margin-top:.35rem;">Contacts, orders, and revenue tracking</p>
            <span class="badge badge--success" style="margin-top:.5rem;">Active</span>
        </div>
        <div style="background:#E8F5E9; border-radius:8px; padding:1rem;">
            <strong>📊 Dynamix Finance</strong>
            <p style="font-size:.8rem; color:var(--text-light); margin-top:.35rem;">GL accounts, journal entries, AR posting</p>
            <span class="badge badge--success" style="margin-top:.5rem;">Active</span>
        </div>
        <div style="background:#F3F2F1; border-radius:8px; padding:1rem;">
            <strong>📦 Supply Chain</strong>
            <p style="font-size:.8rem; color:var(--text-light); margin-top:.35rem;">Inventory and purchasing</p>
            <span class="badge badge--pending" style="margin-top:.5rem;">Coming Soon</span>
        </div>
        <div style="background:#F3F2F1; border-radius:8px; padding:1rem;">
            <strong>👥 HR</strong>
            <p style="font-size:.8rem; color:var(--text-light); margin-top:.35rem;">Employee management and payroll</p>
            <span class="badge badge--pending" style="margin-top:.5rem;">Coming Soon</span>
        </div>
    </div>
</div>
