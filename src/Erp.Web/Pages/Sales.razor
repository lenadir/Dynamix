@page "/sales"
@page "/app/sales"
@attribute [Authorize]
@inject IHttpClientFactory HttpFactory

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
    <div>
        <h2 style="margin-bottom:.25rem;">Sales Orders</h2>
        <p style="color:var(--text-light); font-size:.9rem;">Manage and track all sales orders for your tenant.</p>
    </div>
    <a href="/app/sales/create" class="btn btn--brand btn--sm">+ New Order</a>
</div>

@if (_loading)
{
    <div style="padding:3rem; text-align:center;"><span class="spinner"></span> <span style="margin-left:.5rem; color:var(--text-light);">Loading orders...</span></div>
}
else if (_orders is null || _orders.Count == 0)
{
    <div class="data-table-wrap" style="padding:3rem; text-align:center;">
        <p style="font-size:1.1rem; margin-bottom:.5rem;">No sales orders found</p>
        <p style="color:var(--text-light); margin-bottom:1rem;">Create your first order to get started.</p>
        <a href="/app/sales/create" class="btn btn--brand btn--sm">Create Sales Order</a>
    </div>
}
else
{
    <div class="data-table-wrap">
        <div class="data-table-wrap__header">
            <h3>@_orders.Count order(s)</h3>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Order Number</th>
                    <th>Date</th>
                    <th style="text-align:right;">Total</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in _orders)
                {
                    <tr>
                        <td><strong>@o.OrderNumber</strong></td>
                        <td>@o.Date.ToString("MMM dd, yyyy")</td>
                        <td style="text-align:right; font-weight:600;">@o.Total.ToString("C")</td>
                        <td><span class="badge badge--success">Confirmed</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<OrderRow>? _orders;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpFactory.CreateClient("ErpApi");
            _orders = await client.GetFromJsonAsync<List<OrderRow>>("api/sales/orders") ?? new();
        }
        catch
        {
            _orders = new();
        }
        _loading = false;
    }

    private record OrderRow(Guid Id, string OrderNumber, DateTime Date, decimal Total);
}
