@page "/products"

<section class="hero" style="padding:3rem 2rem 2.5rem;">
    <div class="hero__content">
        <span class="hero__badge">All Products</span>
        <h1 style="font-size:2.2rem;">Choose a Dynamix product to try</h1>
        <p>Select a module below and start your free trial with a guided setup wizard.</p>
    </div>
</section>

<section class="section">
    <div class="section__inner">
        <div class="modules-grid">
            <div class="module-card">
                <div class="module-card__icon module-card__icon--sales">💼</div>
                <h3>Dynamix Sales</h3>
                <p>End-to-end sales order management. Create contacts, manage orders with multi-line items, automatic totals, and real-time order tracking.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>Contact &amp; customer management</li>
                    <li>Multi-line sales order creation</li>
                    <li>Automatic order numbering</li>
                    <li>Cross-module event publishing</li>
                </ul>
                <div class="module-card__footer">
                    <a href="/trial/sales" class="btn btn--brand btn--sm">Try Dynamix Sales Free</a>
                </div>
            </div>

            <div class="module-card">
                <div class="module-card__icon module-card__icon--finance">📊</div>
                <h3>Dynamix Finance</h3>
                <p>Complete financial management with chart of accounts, journal entries, and automated posting from business events.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>General ledger &amp; chart of accounts</li>
                    <li>Double-entry journal entries</li>
                    <li>Idempotent event-driven posting</li>
                    <li>Accounts receivable automation</li>
                </ul>
                <div class="module-card__footer">
                    <a href="/trial/finance" class="btn btn--brand btn--sm">Try Dynamix Finance Free</a>
                </div>
            </div>

            <div class="module-card">
                <div class="module-card__icon module-card__icon--supply">📦</div>
                <h3>Dynamix Supply Chain</h3>
                <p>Optimize your supply chain with inventory management, purchase orders, and warehouse operations.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>Inventory tracking</li>
                    <li>Purchase order management</li>
                    <li>Warehouse operations</li>
                    <li>Demand forecasting</li>
                </ul>
                <div class="module-card__footer">
                    <span class="btn btn--sm" style="opacity:.5; cursor:default; background:#E1DFDD; color:var(--text-light);">Coming Soon</span>
                </div>
            </div>

            <div class="module-card">
                <div class="module-card__icon module-card__icon--service">🎧</div>
                <h3>Dynamix Customer Service</h3>
                <p>Deliver exceptional service with case management, SLA tracking, and a built-in knowledge base.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>Case management</li>
                    <li>SLA tracking &amp; escalation</li>
                    <li>Knowledge base</li>
                    <li>Customer satisfaction surveys</li>
                </ul>
                <div class="module-card__footer">
                    <span class="btn btn--sm" style="opacity:.5; cursor:default; background:#E1DFDD; color:var(--text-light);">Coming Soon</span>
                </div>
            </div>

            <div class="module-card">
                <div class="module-card__icon module-card__icon--hr">👥</div>
                <h3>Dynamix HR</h3>
                <p>Manage your workforce end-to-end: employee records, payroll, leave management, and performance reviews.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>Employee management</li>
                    <li>Payroll processing</li>
                    <li>Leave &amp; attendance</li>
                    <li>Performance reviews</li>
                </ul>
                <div class="module-card__footer">
                    <span class="btn btn--sm" style="opacity:.5; cursor:default; background:#E1DFDD; color:var(--text-light);">Coming Soon</span>
                </div>
            </div>

            <div class="module-card">
                <div class="module-card__icon module-card__icon--project">📋</div>
                <h3>Dynamix Project Operations</h3>
                <p>Plan projects, allocate resources, track time and expenses, and automate billing for project-based work.</p>
                <ul style="font-size:.85rem; color:var(--text-light); margin-bottom:1.25rem; padding-left:1.2rem;">
                    <li>Project planning &amp; scheduling</li>
                    <li>Resource allocation</li>
                    <li>Time &amp; expense tracking</li>
                    <li>Billing automation</li>
                </ul>
                <div class="module-card__footer">
                    <span class="btn btn--sm" style="opacity:.5; cursor:default; background:#E1DFDD; color:var(--text-light);">Coming Soon</span>
                </div>
            </div>
        </div>
    </div>
</section>
