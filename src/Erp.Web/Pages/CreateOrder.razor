@page "/sales/create"
@page "/app/sales/create"
@attribute [Authorize]
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav

<div style="max-width:640px;">
    <h2 style="margin-bottom:.25rem;">Create Sales Order</h2>
    <p style="color:var(--text-light); font-size:.9rem; margin-bottom:1.5rem;">Add a new sales order for the current tenant.</p>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert--error">@_error</div>
    }

    @if (_success)
    {
        <div class="alert alert--success">
            Order created successfully! <a href="/app/sales">View all orders →</a>
        </div>
    }

    <div class="data-table-wrap" style="padding:1.5rem;">
        <div class="form-group">
            <label>Customer</label>
            <select @bind="_customerId" style="width:100%;">
                <option value="22222222-2222-2222-2222-222222222222">Acme Inc. (22222222...)</option>
            </select>
        </div>

        <h4 style="font-size:.9rem; color:var(--text-light); margin:1.25rem 0 .75rem;">ORDER LINES</h4>
        @for (int i = 0; i < _lines.Count; i++)
        {
            var idx = i;
            <div style="background:#F9F9FB; border-radius:var(--radius, 8px); padding:1rem; margin-bottom:.75rem;">
                <div class="form-row">
                    <div class="form-group" style="margin-bottom:.5rem;">
                        <label>Product ID</label>
                        <input @bind="_lines[idx].ProductId" />
                    </div>
                    <div class="form-group" style="margin-bottom:.5rem;">
                        <label>Quantity</label>
                        <input type="number" min="1" @bind="_lines[idx].Qty" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group" style="margin-bottom:0;">
                        <label>Unit Price</label>
                        <input type="number" step="0.01" @bind="_lines[idx].Price" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label>Line Total</label>
                        <input readonly value="@((_lines[idx].Qty * _lines[idx].Price).ToString("C"))" style="background:#F3F2F1;" />
                    </div>
                </div>
                @if (_lines.Count > 1)
                {
                    <button style="margin-top:.5rem; font-size:.8rem; color:#A80000; background:none; border:none; cursor:pointer;"
                            @onclick="() => _lines.RemoveAt(idx)">Remove line</button>
                }
            </div>
        }

        <button class="btn btn--sm btn--outline" style="color:var(--brand); border-color:var(--brand); margin-bottom:1.25rem;"
                @onclick="() => _lines.Add(new LineModel())">+ Add Line</button>

        <div style="padding:1rem; background:#F3F2F1; border-radius:8px; text-align:right; margin-bottom:1.5rem;">
            <span style="font-size:.9rem; color:var(--text-light);">Order Total:</span>
            <strong style="font-size:1.3rem; margin-left:.5rem;">@_lines.Sum(l => l.Qty * l.Price).ToString("C")</strong>
        </div>

        <div style="display:flex; gap:1rem;">
            <button class="btn btn--brand" @onclick="Submit" disabled="@_submitting">
                @if (_submitting) { <span class="spinner"></span> <span>Creating...</span> }
                else { <span>Create Order</span> }
            </button>
            <a href="/app/sales" class="btn btn--outline" style="color:var(--text); border-color:#E1DFDD;">Cancel</a>
        </div>
    </div>
</div>

@code {
    private string _customerId = "22222222-2222-2222-2222-222222222222";
    private List<LineModel> _lines = new() { new() };
    private bool _submitting;
    private bool _success;
    private string? _error;

    private class LineModel
    {
        public string ProductId { get; set; } = "33333333-3333-3333-3333-333333333333";
        public decimal Qty { get; set; } = 2;
        public decimal Price { get; set; } = 49.99m;
    }

    private async Task Submit()
    {
        _submitting = true;
        _error = null;
        _success = false;
        try
        {
            var client = HttpFactory.CreateClient("ErpApi");
            var payload = new
            {
                CustomerId = Guid.Parse(_customerId),
                Lines = _lines.Select(l => new
                {
                    ProductId = Guid.Parse(l.ProductId),
                    Quantity = l.Qty,
                    UnitPrice = l.Price
                }).ToArray()
            };
            var response = await client.PostAsJsonAsync("api/sales/orders", payload);
            if (response.IsSuccessStatusCode)
            {
                _success = true;
                _lines = new() { new() };
            }
            else
                _error = $"API returned {response.StatusCode}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _submitting = false;
    }
}
