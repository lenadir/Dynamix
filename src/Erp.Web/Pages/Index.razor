@page "/"

<!-- ═══ Hero Section ═══ -->
<section class="hero">
    <div class="hero__content">
        <span class="hero__badge">Modular-Monolith ERP</span>
        <h1>Transform your business with Dynamix 365</h1>
        <p>An intelligent, adaptable ERP platform built on .NET 8 — unify sales, finance, and operations in one modular system.</p>
        <div class="hero__actions">
            <a href="/products" class="btn btn--primary">Try for Free</a>
            <a href="/app/dashboard" class="btn btn--outline">Explore Demo</a>
        </div>
    </div>
</section>

<!-- ═══ Value Propositions ═══ -->
<section class="section section--white">
    <div class="section__inner">
        <h2 class="section__title">Why Dynamix?</h2>
        <p class="section__subtitle">Purpose-built ERP modules that work together seamlessly, powered by domain-driven design and clean architecture.</p>
        <div class="features-row">
            <div class="feature-item">
                <div class="feature-item__icon">🔗</div>
                <h4>Modular by Design</h4>
                <p>Add or remove bounded-context modules independently. Sales, Finance, Inventory — each module is self-contained.</p>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">🏢</div>
                <h4>Multi-Tenant</h4>
                <p>Shared-schema architecture with global query filters ensures complete data isolation between tenants.</p>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">⚡</div>
                <h4>Event-Driven</h4>
                <p>Cross-module communication via MassTransit and RabbitMQ. Sales orders automatically generate journal entries.</p>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">🚀</div>
                <h4>Production-Ready</h4>
                <p>Docker Compose, health checks, Serilog, Swagger API docs, and GitHub Actions CI built in from day one.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══ Module Highlights ═══ -->
<section class="section">
    <div class="section__inner">
        <h2 class="section__title">Explore Dynamix products</h2>
        <p class="section__subtitle">Choose a module to start your free trial. Experience the power of integrated ERP.</p>
        <div class="modules-grid">
            <div class="module-card">
                <div class="module-card__icon module-card__icon--sales">💼</div>
                <h3>Dynamix Sales</h3>
                <p>Manage contacts, create sales orders, and track revenue. Automated order numbering, line-item calculations, and real-time totals.</p>
                <div class="module-card__footer">
                    <a href="/trial/sales" class="btn btn--brand btn--sm">Try for Free</a>
                    <a href="/app/sales" style="font-size:.85rem;">View demo &rarr;</a>
                </div>
            </div>
            <div class="module-card">
                <div class="module-card__icon module-card__icon--finance">📊</div>
                <h3>Dynamix Finance</h3>
                <p>Chart of accounts, double-entry journal entries, and automated AR/revenue posting from sales events. Full audit trail.</p>
                <div class="module-card__footer">
                    <a href="/trial/finance" class="btn btn--brand btn--sm">Try for Free</a>
                    <a href="/app/finance" style="font-size:.85rem;">View demo &rarr;</a>
                </div>
            </div>
            <div class="module-card">
                <div class="module-card__icon module-card__icon--supply">📦</div>
                <h3>Dynamix Supply Chain</h3>
                <p>Inventory management, purchase orders, warehouse operations, and demand forecasting. (Coming soon)</p>
                <div class="module-card__footer">
                    <span class="btn btn--sm btn--disabled" style="opacity:.5;">Coming Soon</span>
                </div>
            </div>
            <div class="module-card">
                <div class="module-card__icon module-card__icon--service">🎧</div>
                <h3>Dynamix Customer Service</h3>
                <p>Case management, SLA tracking, knowledge base, and customer satisfaction surveys. (Coming soon)</p>
                <div class="module-card__footer">
                    <span class="btn btn--sm btn--disabled" style="opacity:.5;">Coming Soon</span>
                </div>
            </div>
            <div class="module-card">
                <div class="module-card__icon module-card__icon--hr">👥</div>
                <h3>Dynamix HR</h3>
                <p>Employee management, payroll processing, leave tracking, and performance reviews. (Coming soon)</p>
                <div class="module-card__footer">
                    <span class="btn btn--sm btn--disabled" style="opacity:.5;">Coming Soon</span>
                </div>
            </div>
            <div class="module-card">
                <div class="module-card__icon module-card__icon--project">📋</div>
                <h3>Dynamix Project Operations</h3>
                <p>Project planning, resource scheduling, time & expense tracking, and billing automation. (Coming soon)</p>
                <div class="module-card__footer">
                    <span class="btn btn--sm btn--disabled" style="opacity:.5;">Coming Soon</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ CTA Banner ═══ -->
<section class="hero" style="padding:3rem 2rem;">
    <div class="hero__content">
        <h2 style="font-size:2rem;">Ready to get started?</h2>
        <p style="font-size:1rem;">Start your free trial today. No credit card required.</p>
        <div class="hero__actions">
            <a href="/products" class="btn btn--primary">Start Free Trial</a>
        </div>
    </div>
</section>
